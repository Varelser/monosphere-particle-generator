{
  "name": "kalokagathia",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:public": "vite --mode public",
    "typecheck": "tsc --noEmit",
    "build": "npm run typecheck && vite build",
    "build:github-pages": "npm run typecheck && vite build --base /hp/ && node scripts/prepare-github-pages.mjs",
    "build:github-pages-public": "npm run typecheck && vite build --mode public --base /hp/ && node scripts/prepare-github-pages.mjs",
    "preview": "vite preview",
    "sync:public-library": "node scripts/sync-public-library.mjs",
    "verify:public-library": "node scripts/verify-public-library.mjs",
    "verify:public-ui": "node scripts/verify-public-ui.mjs",
    "verify:export": "node scripts/verify-export.mjs",
    "verify:audio": "node scripts/verify-audio.mjs",
    "verify:standalone-synth": "node scripts/verify-standalone-synth.mjs",
    "verify:video-audio": "node scripts/verify-video-audio.mjs",
    "verify:collision": "node scripts/verify-collision.mjs",
    "verify:shared-audio": "node scripts/verify-shared-audio.mjs",
    "verify:library": "node scripts/verify-library.mjs",
    "verify:video": "node scripts/verify-video.mjs",
    "verify:frames": "node scripts/verify-frames.mjs",
    "prepare:github-pages": "node scripts/prepare-github-pages.mjs"
  },
  "dependencies": {
    "@react-three/drei": "9.99.0",
    "@react-three/fiber": "8.15.16",
    "@react-three/postprocessing": "^3.0.4",
    "debounce": "2.0.0",
    "its-fine": "1.2.5",
    "jszip": "^3.10.1",
    "lucide-react": "0.344.0",
    "maath": "0.10.7",
    "postprocessing": "^6.39.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-reconciler": "0.29.0",
    "react-use-measure": "2.1.1",
    "scheduler": "0.23.0",
    "three": "0.160.0",
    "three-stdlib": "2.29.4",
    "zustand": "4.5.2"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "playwright": "^1.58.2",
    "pngjs": "^7.0.0",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
